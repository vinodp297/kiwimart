{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["sfo1"],
  "crons": [
    {
      "path": "/api/cron/auto-release",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/expire-listings",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/stripe-reconciliation",
      "schedule": "0 14 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
