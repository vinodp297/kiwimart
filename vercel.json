{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["sfo1"],
  "crons": [
    {
      "path": "/api/cron/auto-release",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/dispute-auto-resolve",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/expire-listings",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/delivery-reminders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/stripe-reconciliation",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/seller-downgrade",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/price-drop-alerts",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/release-stale-reservations",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
