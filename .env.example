# .env.local  —  KiwiMart Sprint 3 Environment Variables
# Copy this file to .env.local and fill in all values before running.
# NEVER commit .env.local to git (it's in .gitignore by default in Next.js).
#
# See: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: NEXT_PUBLIC_APP_URL=https://kiwimart.co.nz

# ─────────────────────────────────────────────────────────────────────────────
# Database — Neon PostgreSQL
# Get from: https://console.neon.tech → your project → Connection Details
#
# DATABASE_URL         → Prisma Accelerate pooled URL (for app queries)
# DATABASE_DIRECT_URL  → Direct Neon URL (for migrations only)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=REPLACE_WITH_PRISMA_ACCELERATE_KEY"
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Without Prisma Accelerate (local dev only — use direct URL for both):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
# DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────────
# Auth.js v5
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_BASE64_STRING"
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://kiwimart.co.nz"

# Google OAuth (optional — for Google sign-in)
# Create at: https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="REPLACE_WITH_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="REPLACE_WITH_GOOGLE_CLIENT_SECRET"

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Turnstile (bot protection on login/register forms)
# Get from: https://dash.cloudflare.com → Turnstile → Add Site
# Use site key "1x00000000000000000000AA" for testing (always passes)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
CLOUDFLARE_TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ─────────────────────────────────────────────────────────────────────────────
# Stripe
# Get from: https://dashboard.stripe.com → Developers → API Keys
# Use test keys (sk_test_...) for development
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE"
STRIPE_SECRET_KEY="sk_test_REPLACE"
# Webhook secret from: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_REPLACE"

# ─────────────────────────────────────────────────────────────────────────────
# Postmark (transactional email)
# Get from: https://account.postmarkapp.com → Servers → API Tokens
# ─────────────────────────────────────────────────────────────────────────────
POSTMARK_SERVER_TOKEN="REPLACE_WITH_POSTMARK_SERVER_TOKEN"
EMAIL_FROM="KiwiMart <noreply@kiwimart.co.nz>"

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare R2 (image storage)
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# ─────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID="REPLACE_WITH_ACCOUNT_ID"
R2_BUCKET_NAME="kiwimart-listings"
R2_ACCESS_KEY_ID="REPLACE_WITH_R2_ACCESS_KEY"
R2_SECRET_ACCESS_KEY="REPLACE_WITH_R2_SECRET_KEY"
# Public R2 domain (set up custom domain in R2 dashboard)
NEXT_PUBLIC_R2_PUBLIC_URL="https://r2.kiwimart.co.nz"

# ─────────────────────────────────────────────────────────────────────────────
# Upstash Redis (rate limiting)
# Get from: https://console.upstash.com → Create Database → REST API
# ─────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://REPLACE.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE_WITH_UPSTASH_TOKEN"

# ─────────────────────────────────────────────────────────────────────────────
# Sprint 4 (Pusher, BullMQ — not needed yet)
# ─────────────────────────────────────────────────────────────────────────────
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=ap4
# NEXT_PUBLIC_PUSHER_KEY=
# NEXT_PUBLIC_PUSHER_CLUSTER=ap4

