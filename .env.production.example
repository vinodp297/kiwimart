# .env.production.example
# ─── Production Environment Variables ────────────────────────────────────────
# Copy this file and fill in real values before deploying.
# NEVER commit real secrets — this file contains only placeholders.
#
# Verify all vars are set: npm run check-env

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://kiwimart.co.nz"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_BASE64_STRING"
NEXTAUTH_URL="https://kiwimart.co.nz"

# ─── Database — Neon PostgreSQL ───────────────────────────────────────────────
# Get from: https://console.neon.tech → Connection Details
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=REPLACE_WITH_PRISMA_ACCELERATE_KEY"
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ─── Stripe (use LIVE keys in production) ────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_REPLACE"
STRIPE_SECRET_KEY="sk_live_REPLACE"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE"

# ─── Pusher (real-time messaging) ────────────────────────────────────────────
# Get from: https://dashboard.pusher.com → App Keys
PUSHER_APP_ID="REPLACE"
PUSHER_KEY="REPLACE"
PUSHER_SECRET="REPLACE"
PUSHER_CLUSTER="ap4"
NEXT_PUBLIC_PUSHER_KEY="REPLACE"
NEXT_PUBLIC_PUSHER_CLUSTER="ap4"

# ─── Cloudflare R2 (image storage) ───────────────────────────────────────────
# Get from: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
CLOUDFLARE_ACCOUNT_ID="REPLACE"
R2_BUCKET_NAME="kiwimart-listings"
R2_ACCESS_KEY_ID="REPLACE"
R2_SECRET_ACCESS_KEY="REPLACE"
NEXT_PUBLIC_R2_PUBLIC_URL="https://r2.kiwimart.co.nz"

# ─── Upstash Redis (rate limiting + caching) ─────────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL="https://REPLACE.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE_WITH_UPSTASH_TOKEN"

# ─── IORedis / BullMQ (job queues) ───────────────────────────────────────────
REDIS_URL="redis://REPLACE:6379"

# ─── Email — Resend ──────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY="re_REPLACE"
EMAIL_FROM="KiwiMart <noreply@kiwimart.co.nz>"

# ─── Internal API secrets ────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CRON_SECRET="REPLACE_WITH_32_CHAR_SECRET"
WORKER_SECRET="REPLACE_WITH_32_CHAR_SECRET"

# ─── Optional ────────────────────────────────────────────────────────────────
# Sentry (error tracking) — get from: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=""
# PostHog (analytics) — get from: https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
# Cloudflare Turnstile (bot protection)
CLOUDFLARE_TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
