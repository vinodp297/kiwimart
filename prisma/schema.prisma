// prisma/schema.prisma
// ─── KiwiMart — Production Prisma Schema ─────────────────────────────────────
// Database: Neon PostgreSQL (serverless)
// ORM: Prisma 7 with Accelerate for connection pooling at the edge
//
// Conventions:
//   • All IDs: cuid2 (collision-resistant, URL-safe, no timestamp leakage)
//   • All timestamps: UTC, stored as DateTime
//   • Soft deletes: deletedAt nullable field (never hard-delete listings/orders)
//   • Row-level security enforced via Prisma middleware in Sprint 4 (not in schema)
//   • Money: stored as INTEGER cents (NZD) — never floating point
//   • Ratings: stored as INTEGER 1–50 (represents 0.1–5.0 with 1 decimal)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  PARTS
}

enum ListingStatus {
  DRAFT
  ACTIVE
  RESERVED
  SOLD
  EXPIRED
  REMOVED
}

enum ShippingOption {
  PICKUP
  COURIER
  BOTH
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAYMENT_HELD
  DISPATCHED
  DELIVERED
  COMPLETED
  DISPUTED
  REFUNDED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum DisputeReason {
  ITEM_NOT_RECEIVED
  ITEM_NOT_AS_DESCRIBED
  ITEM_DAMAGED
  WRONG_ITEM_SENT
  COUNTERFEIT_ITEM
  SELLER_UNRESPONSIVE
  SELLER_CANCELLED
  REFUND_NOT_PROCESSED
  OTHER
}

enum AuditAction {
  USER_REGISTER
  USER_LOGIN
  USER_LOGOUT
  USER_PASSWORD_CHANGED
  USER_EMAIL_CHANGED
  LISTING_CREATED
  LISTING_UPDATED
  LISTING_DELETED
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  OFFER_CREATED
  OFFER_ACCEPTED
  OFFER_DECLINED
  PAYMENT_INITIATED
  PAYMENT_COMPLETED
  PAYMENT_FAILED
  PAYOUT_INITIATED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  ADMIN_ACTION
  PHONE_VERIFIED
  REPORT_CREATED
  PASSWORD_CHANGED
  SELLER_TERMS_ACCEPTED
  ID_VERIFICATION_SUBMITTED
  ID_VERIFICATION_APPROVED
  DISPUTE_SELLER_RESPONDED
  CART_CHECKOUT
  SELLER_VERIFICATION_APPLIED
  SELLER_VERIFICATION_APPROVED
  SELLER_VERIFICATION_REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReportReason {
  SCAM
  COUNTERFEIT
  PROHIBITED
  OFFENSIVE
  SPAM
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum AdminRole {
  SUPER_ADMIN
  FINANCE_ADMIN
  DISPUTES_ADMIN
  TRUST_SAFETY_ADMIN
  SUPPORT_ADMIN
  SELLER_MANAGER
  READ_ONLY_ADMIN
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified      DateTime?
  emailVerifyToken   String?   @unique  // Single-use token for email verification
  emailVerifyExpires DateTime?
  username           String    @unique
  displayName   String

  // Auth — password stored as Argon2id hash, never plaintext
  // Min cost: 3, memory: 64MB, parallelism: 1 (OWASP recommendation)
  passwordHash  String?
  
  // OAuth accounts (Auth.js)
  accounts      Account[]
  sessions      Session[]

  // Profile
  avatarKey      String?   // Cloudflare R2 object key (not URL — generate signed URLs at request time)
  coverImageKey  String?   // Cloudflare R2 object key for profile cover/banner image
  bio            String?   @db.Text
  phone           String?
  phoneVerified   Boolean   @default(false)
  phoneVerifiedAt DateTime?
  dateOfBirth     DateTime? // For age verification, never surfaced in UI
  
  // NZ location
  region        String?
  suburb        String?
  
  // Verification
  idVerified    Boolean  @default(false)
  idVerifiedAt  DateTime?
  idSubmittedAt DateTime?           // When user requested ID verification (pending admin review)
  nzbn          String?  @unique  // NZ Business Number (GST-registered sellers)
  gstRegistered Boolean  @default(false)

  // Seller settings
  sellerTermsAcceptedAt DateTime?          // Accepted seller T&Cs
  sellerEnabled       Boolean @default(true)
  stripeAccountId     String? @unique  // Stripe Connect account ID
  stripeOnboarded     Boolean @default(false)
  stripeChargesEnabled  Boolean @default(false)  // Synced from Stripe account.updated webhook
  stripePayoutsEnabled  Boolean @default(false)  // Synced from Stripe account.updated webhook
  /// Stores masked display string only (e.g. "ANZ ****1234").
  /// Full banking details are stored in Stripe Connect — never in our DB.
  /// Populated from Stripe external_account data via account.updated webhook.
  payoutBankAccount   String?

  // Seller verification & trust (Feature P1-1, P1-2, P1-4)
  isVerifiedSeller       Boolean   @default(false)
  verifiedSellerAt       DateTime?
  avgResponseTimeMinutes Int?       // rolling average response time
  responseRate           Float?     // % of threads replied to within 24hrs
  lastResponseCalcAt     DateTime?

  // Radius search (Feature P2-1)
  searchLat    Float?
  searchLng    Float?
  searchRadius Int?    @default(50)

  // Flags
  isBanned      Boolean  @default(false)
  bannedAt      DateTime?
  bannedReason  String?
  isAdmin       Boolean  @default(false)
  adminRole     AdminRole?  // null = not admin; set alongside isAdmin
  
  // Onboarding
  onboardingCompleted Boolean @default(false)
  onboardingIntent    String?  // 'BUY' | 'SELL' | 'BOTH'

  // Privacy
  agreeMarketing Boolean @default(false)
  agreedTermsAt  DateTime?

  // Timestamps
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime? // Soft delete (GDPR right to erasure)

  // Relations
  listings       Listing[]
  buyerOrders    Order[]    @relation("BuyerOrders")
  sellerOrders   Order[]    @relation("SellerOrders")
  offers         Offer[]    @relation("BuyerOffers")
  receivedOffers Offer[]    @relation("SellerOffers")
  reviews        Review[]   @relation("ReviewedSeller")
  writtenReviews Review[]   @relation("ReviewAuthor")
  sentMessages   Message[]  @relation("MessageSender")
  watchlist      WatchlistItem[]
  passwordResets PasswordResetToken[]
  emailVerTokens EmailVerificationToken[]
  auditLogs      AuditLog[]
  payouts        Payout[]
  phoneTokens    PhoneVerificationToken[]
  reportsFiled   Report[]   @relation("ReportFiler")
  reportsReceived Report[]  @relation("ReportTarget")
  invitationsSent AdminInvitation[] @relation("InvitedBy")
  notifications   Notification[]
  blocksGiven     BlockedUser[]  @relation("UserBlocks")
  blocksReceived  BlockedUser[]  @relation("UserBlockedBy")
  cart            Cart?
  verificationApplication VerificationApplication?
  recentlyViewed  RecentlyViewed[]

  @@index([email])
  @@index([username])
  @@index([createdAt])
}

// Auth.js required models ─────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Security tokens
// ─────────────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  // Store the HASH of the token — raw token sent by email only, never stored
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  
  // IP and user-agent for audit trail
  requestIp String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Listings
// ─────────────────────────────────────────────────────────────────────────────

model Listing {
  id          String         @id @default(cuid())
  sellerId    String
  
  title       String         @db.VarChar(100)
  description String         @db.Text
  
  // Price in NZD cents (integer — no floating point money)
  priceNzd    Int
  gstIncluded Boolean        @default(false)
  
  condition    ListingCondition
  status       ListingStatus    @default(DRAFT)
  
  // Category
  categoryId      String
  subcategoryName String?
  
  // Location
  region  String
  suburb  String
  
  // Shipping
  shippingOption ShippingOption
  // Shipping price in NZD cents; null = free or pickup-only
  shippingNzd    Int?
  pickupAddress  String?
  
  // Commerce
  offersEnabled Boolean @default(true)

  // Quick-filter flags (Feature: Quick Filter Chips)
  isUrgent        Boolean  @default(false)  // Seller needs to sell fast
  isNegotiable    Boolean  @default(false)  // Price is negotiable
  shipsNationwide Boolean  @default(false)  // Ships anywhere in NZ

  // Price-drop tracking (Feature: Price Dropped badge)
  previousPriceNzd Int?      // Last price before a drop (cents)
  priceDroppedAt   DateTime? // When the last price drop occurred

  // Engagement counters (denormalised for query performance)
  viewCount    Int @default(0)
  watcherCount Int @default(0)
  
  // Location coordinates for radius search (Feature P2-1)
  locationLat  Float?
  locationLng  Float?

  // Full-text search vector (maintained by Postgres trigger)
  searchVector Unsupported("tsvector")?
  
  // Lifecycle
  publishedAt DateTime?
  expiresAt   DateTime?
  soldAt      DateTime?
  
  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relations
  seller    User            @relation(fields: [sellerId], references: [id])
  images    ListingImage[]
  attrs     ListingAttribute[]
  orders    Order[]
  offers    Offer[]
  watchers     WatchlistItem[]
  cartItems    CartItem[]
  priceHistory ListingPriceHistory[]
  recentViews  RecentlyViewed[]

  @@index([sellerId])
  @@index([status])
  @@index([categoryId])
  @@index([region])
  @@index([priceNzd])
  @@index([createdAt])
  @@index([searchVector], type: Gin)
  @@index([locationLat, locationLng])
  @@index([sellerId, createdAt(sort: Desc)])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String?  // null = pending upload (not yet associated with a listing)
  r2Key     String   // Cloudflare R2 object key
  altText   String?
  order     Int     @default(0)
  width     Int?
  height    Int?
  sizeBytes         Int?
  thumbnailKey      String?
  processedAt       DateTime?
  originalSizeBytes Int?
  // ClamAV scan result — never serve images that haven't been scanned
  scanned   Boolean @default(false)
  safe      Boolean @default(false)
  scannedAt DateTime?

  listing Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([listingId, order])
}

model ListingAttribute {
  id        String @id @default(cuid())
  listingId String
  label     String @db.VarChar(50)
  value     String @db.VarChar(200)
  order     Int    @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Orders
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id        String @id @default(cuid())
  buyerId   String
  sellerId  String
  listingId String
  
  // Prices in NZD cents at time of purchase (snapshot — listing price may change)
  itemNzd     Int
  shippingNzd Int  @default(0)
  totalNzd    Int
  
  status  OrderStatus @default(AWAITING_PAYMENT)
  
  // Stripe
  stripePaymentIntentId String? @unique
  stripeTransferId      String? // Transfer to seller's Connect account
  
  // Delivery
  trackingNumber String?
  trackingUrl    String?
  dispatchedAt   DateTime?
  deliveredAt    DateTime?
  completedAt    DateTime?
  
  // Dispute
  disputeReason       DisputeReason?
  disputeOpenedAt     DateTime?
  disputeNotes        String?       @db.Text
  disputeResolvedAt   DateTime?
  disputeEvidenceUrls String[]  @default([])
  sellerResponse      String?       @db.Text
  sellerRespondedAt   DateTime?

  // Cancellation
  cancelledBy  String?    // 'BUYER' | 'SELLER' | 'SYSTEM'
  cancelReason String?    @db.Text
  cancelledAt  DateTime?
  
  // Shipping address (snapshot)
  shippingName    String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingRegion  String?
  shippingPostcode String?
  
  idempotencyKey String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer   User    @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller  User    @relation("SellerOrders", fields: [sellerId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])
  review  Review?
  payout  Payout?
  items   OrderItem[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
  @@index([createdAt])
  @@index([status, dispatchedAt])
  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([sellerId, completedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Offers
// ─────────────────────────────────────────────────────────────────────────────

model Offer {
  id        String @id @default(cuid())
  listingId String
  buyerId   String
  sellerId  String
  
  amountNzd Int   // Offer amount in cents
  note      String? @db.VarChar(300)
  
  status    OfferStatus @default(PENDING)
  
  // Expiry — offers expire after 48 hours by default
  expiresAt DateTime

  // Payment deadline — set 24 hours after seller accepts
  // If buyer has not paid by this time the listing is released back to ACTIVE
  paymentDeadline DateTime?

  respondedAt DateTime?
  declineNote String?   @db.VarChar(300)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  buyer   User    @relation("BuyerOffers", fields: [buyerId], references: [id])
  seller  User    @relation("SellerOffers", fields: [sellerId], references: [id])

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([expiresAt])
  @@index([listingId, status])
  @@index([buyerId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Reviews
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id         String @id @default(cuid())
  orderId    String @unique  // One review per order
  sellerId   String
  authorId   String
  
  // Rating stored as integer 1–50 (represents 1.0–5.0 in 0.1 increments)
  rating     Int
  comment    String @db.Text
  
  sellerReply   String?   @db.Text
  sellerRepliedAt DateTime?
  
  // Moderation
  approved    Boolean  @default(true)
  flagged     Boolean  @default(false)
  flagReason  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order  Order @relation(fields: [orderId], references: [id])
  seller User  @relation("ReviewedSeller", fields: [sellerId], references: [id])
  author User  @relation("ReviewAuthor", fields: [authorId], references: [id])
  tags   ReviewTag[]

  @@index([sellerId])
  @@index([authorId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Messaging
// ─────────────────────────────────────────────────────────────────────────────

model MessageThread {
  id          String @id @default(cuid())
  listingId   String?
  participant1Id String
  participant2Id String
  
  lastMessageAt DateTime @default(now())
  
  createdAt DateTime @default(now())

  messages Message[]

  @@unique([participant1Id, participant2Id, listingId])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
}

model Message {
  id        String @id @default(cuid())
  threadId  String
  senderId  String
  
  body String @db.Text
  read Boolean @default(false)
  readAt DateTime?
  
  // Content moderation
  flagged    Boolean @default(false)
  flagReason String?
  
  createdAt DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("MessageSender", fields: [senderId], references: [id])

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
  @@index([senderId, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// Watchlist
// ─────────────────────────────────────────────────────────────────────────────

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  // Price drop alerts (Feature P1-3)
  priceAlertEnabled Boolean @default(true)
  priceAtWatch      Int?    // price in NZD cents at time of watch

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payouts
// ─────────────────────────────────────────────────────────────────────────────

model Payout {
  id      String @id @default(cuid())
  orderId String @unique
  userId  String

  amountNzd          Int          // Amount in cents after platform fee
  platformFeeNzd     Int          // KiwiMart's cut (0 during beta)
  stripeFeeNzd       Int          // Stripe processing fee
  
  status    PayoutStatus @default(PENDING)
  
  stripeTransferId String? @unique
  
  initiatedAt DateTime?
  paidAt      DateTime?
  failedAt    DateTime?
  failReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit Log — immutable, append-only
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id     String      @id @default(cuid())
  userId String?     // null for system actions
  action AuditAction
  
  // Entity being acted on
  entityType String?
  entityId   String?
  
  // Snapshot of changes (JSON diff)
  metadata   Json?
  
  // Request context for forensics
  ip        String?
  userAgent String?
  
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications — in-app bell notifications for users
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // NotificationType — see notification.service.ts
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?  // Deep-link to relevant page
  listingId String?  // Optional reference for context
  orderId   String?  // Optional reference for context
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Stripe Event Idempotency — prevents duplicate webhook processing
// ─────────────────────────────────────────────────────────────────────────────

model StripeEvent {
  id          String   @id // Stripe event ID e.g. evt_xxx
  type        String
  processedAt DateTime @default(now())

  @@map("stripe_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Categories (managed in code — this table is seeded, not user-editable)
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id           String @id
  name         String @unique
  icon         String // emoji
  slug         String @unique
  displayOrder Int    @default(0)
  active       Boolean @default(true)
  
  subcategories Subcategory[]

  @@index([slug])
}

model Subcategory {
  id         String @id @default(cuid())
  categoryId String
  name       String
  slug       String

  category Category @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, slug])
  @@index([categoryId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Admin Invitations — token-based invite system for onboarding new admin team
// ─────────────────────────────────────────────────────────────────────────────

model AdminInvitation {
  id          String     @id @default(cuid())
  email       String     @unique
  adminRole   AdminRole
  invitedBy   String
  inviter     User       @relation("InvitedBy", fields: [invitedBy], references: [id])
  tokenHash   String     @unique  // SHA-256 hash of the raw token (raw sent in email, never stored)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())

  @@index([tokenHash])
  @@index([email])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phone Verification Tokens
// ─────────────────────────────────────────────────────────────────────────────

model PhoneVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  // Store the HASH of the 6-digit code — raw code sent by SMS only, never stored
  codeHash  String
  phone     String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0) // Track failed verification attempts
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
}

// ─────────────────────────────────────────────────────────────────────────────
// Block User
// ─────────────────────────────────────────────────────────────────────────────

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocks",    fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Reports (Trust & Safety)
// ─────────────────────────────────────────────────────────────────────────────

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  // The user being reported (seller or buyer)
  targetUserId String?
  // The listing being reported (optional)
  listingId   String?

  reason      ReportReason
  description String       @db.Text
  status      ReportStatus @default(OPEN)

  // Admin resolution
  resolvedBy    String?
  resolvedAt    DateTime?
  resolvedNote  String?    @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reporter   User  @relation("ReportFiler", fields: [reporterId], references: [id])
  targetUser User? @relation("ReportTarget", fields: [targetUserId], references: [id])

  @@index([reporterId])
  @@index([targetUserId])
  @@index([listingId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Shopping Cart — single-seller constraint, DB-persisted
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id       String @id @default(cuid())
  userId   String @unique  // One cart per user
  sellerId String          // All items must belong to this seller

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime        // 48 hours after last update

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@index([expiresAt])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  listingId String

  // Price snapshot at time of add (NZD cents) — re-validated at checkout
  priceNzd    Int
  shippingNzd Int @default(0)

  createdAt DateTime @default(now())

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id])

  @@unique([cartId, listingId])  // No duplicate items
  @@index([cartId])
  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Order Items — line items for multi-item orders (cart checkout)
// ─────────────────────────────────────────────────────────────────────────────

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  listingId String

  // Price snapshot at time of purchase (NZD cents)
  priceNzd    Int
  shippingNzd Int @default(0)
  title       String  // Denormalised — listing may change/delete

  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Seller Verification Applications (Feature P1-4)
// ─────────────────────────────────────────────────────────────────────────────

model VerificationApplication {
  id         String             @id @default(cuid())
  sellerId   String             @unique
  seller     User               @relation(fields: [sellerId], references: [id])
  status     VerificationStatus @default(PENDING)
  appliedAt  DateTime           @default(now())
  reviewedAt DateTime?
  reviewedBy String?
  adminNotes String?

  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Listing Price History (Feature P2-2)
// ─────────────────────────────────────────────────────────────────────────────

model ListingPriceHistory {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  priceNzd  Int      // price in NZD cents
  changedAt DateTime @default(now())

  @@index([listingId, changedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Review Tags (buyer-selected strength chips)
// ─────────────────────────────────────────────────────────────────────────────

enum ReviewTagType {
  FAST_SHIPPING
  GREAT_PACKAGING
  ACCURATE_DESCRIPTION
  QUICK_COMMUNICATION
  FAIR_PRICING
  AS_DESCRIBED
}

model ReviewTag {
  id       String        @id @default(cuid())
  reviewId String
  review   Review        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag      ReviewTagType

  @@unique([reviewId, tag])
  @@index([tag])
}

// ─────────────────────────────────────────────────────────────────────────────
// Recently Viewed Listings (authenticated users)
// ─────────────────────────────────────────────────────────────────────────────

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId, viewedAt(sort: Desc)])
}

