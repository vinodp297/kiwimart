// prisma/schema.prisma
// ─── KiwiMart — Production Prisma Schema ─────────────────────────────────────
// Database: Neon PostgreSQL (serverless)
// ORM: Prisma 7 with Accelerate for connection pooling at the edge
//
// Conventions:
//   • All IDs: cuid2 (collision-resistant, URL-safe, no timestamp leakage)
//   • All timestamps: UTC, stored as DateTime
//   • Soft deletes: deletedAt nullable field (never hard-delete listings/orders)
//   • Row-level security enforced via Prisma middleware in Sprint 4 (not in schema)
//   • Money: stored as INTEGER cents (NZD) — never floating point
//   • Ratings: stored as INTEGER 1–50 (represents 0.1–5.0 with 1 decimal)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

