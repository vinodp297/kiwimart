// ─────────────────────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified      DateTime?
  emailVerifyToken   String?   @unique  // Single-use token for email verification
  emailVerifyExpires DateTime?
  username           String    @unique
  displayName   String

  // Auth — password stored as Argon2id hash, never plaintext
  // Min cost: 3, memory: 64MB, parallelism: 1 (OWASP recommendation)
  passwordHash  String?
  
  // OAuth accounts (Auth.js)
  accounts      Account[]
  sessions      Session[]

  // Profile
  avatarKey      String?   // Cloudflare R2 object key (not URL — generate signed URLs at request time)
  coverImageKey  String?   // Cloudflare R2 object key for profile cover/banner image
  bio            String?   @db.Text
  phone           String?
  phoneVerified   Boolean   @default(false)
  phoneVerifiedAt DateTime?
  dateOfBirth     DateTime? // For age verification, never surfaced in UI
  
  // NZ location
  region        String?
  suburb        String?
  
  // Verification
  idVerified    Boolean  @default(false)
  idVerifiedAt  DateTime?
  idSubmittedAt DateTime?           // When user requested ID verification (pending admin review)
  nzbn          String?  @unique  // NZ Business Number (GST-registered sellers)
  gstRegistered Boolean  @default(false)
  gstNumber     String?  // NZ GST number (8-9 digits, format: XX-XXX-XXX)

  // MFA (TOTP-based two-factor authentication)
  mfaSecret      String?   // Encrypted TOTP secret
  mfaEnabled     Boolean   @default(false)
  mfaBackupCodes String?   // Encrypted JSON array of one-time backup codes

  // Seller settings
  sellerTermsAcceptedAt DateTime?          // Accepted seller T&Cs
  sellerEnabled       Boolean @default(true)
  stripeAccountId     String? @unique  // Stripe Connect account ID
  stripeOnboarded     Boolean @default(false)
  stripeChargesEnabled  Boolean @default(false)  // Synced from Stripe account.updated webhook
  stripePayoutsEnabled  Boolean @default(false)  // Synced from Stripe account.updated webhook
  /// Stores masked display string only (e.g. "ANZ ****1234").
  /// Full banking details are stored in Stripe Connect — never in our DB.
  /// Populated from Stripe external_account data via account.updated webhook.
  payoutBankAccount   String?

  // Seller verification & trust (Feature P1-1, P1-2, P1-4)
  isVerifiedSeller       Boolean   @default(false)
  verifiedSellerAt       DateTime?
  avgResponseTimeMinutes Int?       // rolling average response time
  responseRate           Float?     // % of threads replied to within 24hrs
  lastResponseCalcAt     DateTime?

  // Radius search (Feature P2-1)
  searchLat    Float?
  searchLng    Float?
  searchRadius Int?    @default(50)

  // Flags
  isBanned      Boolean  @default(false)
  bannedAt      DateTime?
  bannedReason  String?
  isAdmin       Boolean  @default(false)
  adminRole     AdminRole?  // null = not admin; set alongside isAdmin
  
  // Onboarding
  onboardingCompleted Boolean @default(false)
  onboardingIntent    String?  // 'BUY' | 'SELL' | 'BOTH'

  // Privacy
  agreeMarketing Boolean @default(false)
  agreedTermsAt  DateTime?

  // Timestamps
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime? // Soft delete (GDPR right to erasure)

  // Relations
  listings       Listing[]
  buyerOrders    Order[]    @relation("BuyerOrders")
  sellerOrders   Order[]    @relation("SellerOrders")
  offers         Offer[]    @relation("BuyerOffers")
  receivedOffers Offer[]    @relation("SellerOffers")
  reviewsAbout   Review[]   @relation("ReviewSubject")
  writtenReviews Review[]   @relation("ReviewAuthor")
  sentMessages   Message[]  @relation("MessageSender")
  watchlist      WatchlistItem[]
  passwordResets PasswordResetToken[]
  emailVerTokens EmailVerificationToken[]
  auditLogs      AuditLog[]
  payouts        Payout[]
  phoneTokens    PhoneVerificationToken[]
  reportsFiled   Report[]   @relation("ReportFiler")
  reportsReceived Report[]  @relation("ReportTarget")
  invitationsSent AdminInvitation[] @relation("InvitedBy")
  notifications   Notification[]
  blocksGiven     BlockedUser[]  @relation("UserBlocks")
  blocksReceived  BlockedUser[]  @relation("UserBlockedBy")
  cart            Cart?
  verificationApplication VerificationApplication?
  recentlyViewed         RecentlyViewed[]
  orderEvents            OrderEvent[]        @relation("OrderEventActor")
  initiatedInteractions  OrderInteraction[]  @relation("InteractionInitiator")
  respondedInteractions  OrderInteraction[]  @relation("InteractionResponder")
  trustMetrics           TrustMetrics?
  pickupRescheduleRequests PickupRescheduleRequest[]
  disputeEvidence          DisputeEvidence[]
  platformConfigUpdates    PlatformConfig[]
  dynamicListUpdates       DynamicListItem[] @relation("DynamicListUpdater")

  // Seller tier override (set by admin or automated downgrade)
  sellerTierOverride       String?
  sellerTierOverrideReason String?   @db.Text
  sellerTierOverrideAt     DateTime?
  sellerTierOverrideBy     String?

  @@index([email])
  @@index([username])
  @@index([createdAt])
}

// Auth.js required models ─────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Security tokens
// ─────────────────────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  // Store the HASH of the token — raw token sent by email only, never stored
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  
  // IP and user-agent for audit trail
  requestIp String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Listings
// ─────────────────────────────────────────────────────────────────────────────

model Listing {
  id          String         @id @default(cuid())
  sellerId    String
  
  title       String         @db.VarChar(100)
  description String         @db.Text
  
  // Price in NZD cents (integer — no floating point money)
  priceNzd    Int
  gstIncluded Boolean        @default(false)
  
  condition    ListingCondition
  status       ListingStatus    @default(DRAFT)
  
  // Category
  categoryId      String
  subcategoryName String?
  
  // Location
  region  String
  suburb  String
  
  // Shipping
  shippingOption ShippingOption
  // Shipping price in NZD cents; null = free or pickup-only
  shippingNzd    Int?
  pickupAddress  String?
  
  // Commerce
  offersEnabled Boolean @default(true)

  // Quick-filter flags (Feature: Quick Filter Chips)
  isUrgent        Boolean  @default(false)  // Seller needs to sell fast
  isNegotiable    Boolean  @default(false)  // Price is negotiable
  shipsNationwide Boolean  @default(false)  // Ships anywhere in NZ

  // Price-drop tracking (Feature: Price Dropped badge)
  previousPriceNzd Int?      // Last price before a drop (cents)
  priceDroppedAt   DateTime? // When the last price drop occurred

  // Engagement counters (denormalised for query performance)
  viewCount    Int @default(0)
  watcherCount Int @default(0)
  
  // Location coordinates for radius search (Feature P2-1)
  locationLat  Float?
  locationLng  Float?

  // Full-text search vector (maintained by Postgres trigger)
  searchVector Unsupported("tsvector")?
  
  // Moderation (listing approval system)
  autoRiskScore      Int?       // 0–100 computed risk score from auto-review
  autoRiskFlags      String[]   @default([]) // rule names that triggered (e.g. HIGH_VALUE_ITEM, SINGLE_IMAGE)
  moderationNote     String?    @db.Text // admin message explaining what to fix / reject reason
  moderatedBy        String?    // admin userId who took moderation action
  moderatedAt        DateTime?  // when admin actioned the listing
  resubmissionCount  Int        @default(0)  // how many times seller has resubmitted after changes requested

  // Lifecycle
  publishedAt DateTime?
  expiresAt   DateTime?
  soldAt      DateTime?
  
  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete

  // Relations
  seller    User            @relation(fields: [sellerId], references: [id])
  images    ListingImage[]
  attrs     ListingAttribute[]
  orders    Order[]
  offers    Offer[]
  watchers     WatchlistItem[]
  cartItems    CartItem[]
  priceHistory ListingPriceHistory[]
  recentViews  RecentlyViewed[]
  snapshots    ListingSnapshot[]

  @@index([sellerId])
  @@index([status])
  @@index([categoryId])
  @@index([region])
  @@index([priceNzd])
  @@index([createdAt])
  @@index([searchVector], type: Gin)
  @@index([locationLat, locationLng])
  @@index([sellerId, createdAt(sort: Desc)])
  // Partial index for public browse queries (status=ACTIVE, deletedAt=null)
  @@index([createdAt(sort: Desc), categoryId, region, priceNzd], map: "Listing_active_partial_idx")
  @@index([status, expiresAt], map: "Listing_status_expiresAt_idx")
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String?  // null = pending upload (not yet associated with a listing)
  r2Key     String   // Cloudflare R2 object key
  altText   String?
  order     Int     @default(0)
  width     Int?
  height    Int?
  sizeBytes         Int?
  thumbnailKey      String?
  processedAt       DateTime?
  originalSizeBytes Int?
  // ClamAV scan result — never serve images that haven't been scanned
  scanned   Boolean @default(false)
  safe      Boolean @default(false)
  scannedAt DateTime?

  listing Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([listingId, order])
  @@index([r2Key], map: "ListingImage_r2Key_idx")
}

model ListingAttribute {
  id        String @id @default(cuid())
  listingId String
  label     String @db.VarChar(50)
  value     String @db.VarChar(200)
  order     Int    @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Orders
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id        String @id @default(cuid())
  buyerId   String
  sellerId  String
  listingId String
  
  // Prices in NZD cents at time of purchase (snapshot — listing price may change)
  itemNzd     Int
  shippingNzd Int  @default(0)
  totalNzd    Int
  
  status  OrderStatus @default(AWAITING_PAYMENT)
  
  // Stripe
  stripePaymentIntentId String? @unique
  stripeTransferId      String? // Transfer to seller's Connect account
  
  // Delivery
  trackingNumber String?
  trackingUrl    String?
  dispatchedAt   DateTime?
  deliveredAt    DateTime?
  completedAt    DateTime?
  
  // Dispute (standalone model — one-to-one via orderId @unique)
  dispute             Dispute?

  // Fulfillment
  fulfillmentType         FulfillmentType  @default(SHIPPED)

  // Pickup
  pickupStatus            PickupStatus?
  pickupScheduledAt       DateTime?
  pickupWindowExpiresAt   DateTime?
  otpInitiatedAt          DateTime?
  otpExpiresAt            DateTime?
  otpCodeHash             String?
  rescheduleCount         Int              @default(0)
  pickupConfirmedAt       DateTime?
  pickupRejectedAt        DateTime?
  pickupCancelledAt       DateTime?
  pickupWindowJobId       String?
  scheduleDeadlineJobId   String?
  otpJobId                String?

  // Cancellation
  cancelledBy  String?    // 'BUYER' | 'SELLER' | 'SYSTEM'
  cancelReason String?    @db.Text
  cancelledAt  DateTime?
  
  // Shipping address (snapshot)
  shippingName    String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingRegion  String?
  shippingPostcode String?
  
  idempotencyKey String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer   User    @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller  User    @relation("SellerOrders", fields: [sellerId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])
  reviews Review[]
  payout  Payout?
  snapshot     ListingSnapshot?
  items        OrderItem[]
  events       OrderEvent[]
  interactions OrderInteraction[]
  pickupRescheduleRequests PickupRescheduleRequest[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
  @@index([createdAt])
  @@index([status, dispatchedAt])
  @@index([status, createdAt(sort: Desc)])
  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([sellerId, completedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Disputes (standalone model — one dispute per order)
// ─────────────────────────────────────────────────────────────────────────────
// All dispute data now lives here instead of on the Order model.
// OrderStatus.DISPUTED remains as the queue-filter signal.

model Dispute {
  id                   String          @id @default(cuid())
  orderId              String          @unique

  reason               DisputeReason
  source               DisputeSource   @default(STANDARD)
  status               DisputeStatus   @default(OPEN)

  buyerStatement       String?         @db.Text
  sellerStatement      String?         @db.Text
  adminNotes           String?         @db.Text

  resolution           String?
  refundAmount         Int?

  autoResolutionScore  Int?
  autoResolutionReason String?         @db.Text

  openedAt             DateTime        @default(now())
  sellerRespondedAt    DateTime?
  resolvedAt           DateTime?

  order                Order           @relation(fields: [orderId], references: [id])
  evidence             DisputeEvidence[]

  @@index([status])
  @@index([openedAt])
}

model DisputeEvidence {
  id          String              @id @default(cuid())
  disputeId   String
  uploadedBy  EvidenceUploadedBy
  uploaderId  String

  r2Key       String
  fileType    String              @default("image")
  label       String?

  createdAt   DateTime            @default(now())

  dispute     Dispute             @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  uploader    User                @relation(fields: [uploaderId], references: [id])

  @@index([disputeId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Order Events (audit trail / timeline)
// ─────────────────────────────────────────────────────────────────────────────
// Records every state transition and significant action on an order.
// The UI renders a dynamic timeline from these events.
// type and actorRole are plain Strings (not enums) so new event types
// can be added without migrations.

/// HIGH GROWTH TABLE — Partitioning Strategy:
/// At ~1M rows (est. 12-18 months at 1K DAU), partition by month using
/// PostgreSQL declarative partitioning on createdAt.
/// Migration path: CREATE TABLE order_events_YYYY_MM PARTITION OF order_events
/// FOR VALUES FROM ('YYYY-MM-01') TO ('YYYY-MM-01' + interval '1 month');
/// Archive partitions older than 12 months to cold storage.
/// Index: createdAt DESC already exists — will be inherited by partitions.
model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  type      String   // ORDER_CREATED, PAYMENT_HELD, DISPATCHED, COMPLETED, CANCELLED, etc.
  actorId   String?  // null for SYSTEM actions
  actorRole String   // BUYER, SELLER, ADMIN, SYSTEM
  summary   String   // Human-readable description for timeline UI
  metadata  Json?    // Structured data: tracking numbers, refund amounts, etc.
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User? @relation("OrderEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Order Interactions (active negotiations)
// ─────────────────────────────────────────────────────────────────────────────
// Tracks buyer-seller negotiations that require a response.
// Pattern: one party requests → other responds → resolution or escalation.

model OrderInteraction {
  id             String    @id @default(cuid())
  orderId        String
  type           String    // CANCEL_REQUEST, RETURN_REQUEST, PARTIAL_REFUND_REQUEST, etc.
  status         String    @default("PENDING") // PENDING, ACCEPTED, REJECTED, COUNTERED, EXPIRED, ESCALATED, RESOLVED
  initiatedById  String
  initiatorRole  String    // BUYER or SELLER
  reason         String    @db.Text
  details        Json?     // Amount for partial refund, proposed resolution, counter-offer, etc.
  responseById   String?
  responseNote   String?   @db.Text
  respondedAt    DateTime?
  expiresAt      DateTime  // When auto-action kicks in if no response
  autoAction     String    // AUTO_APPROVE, AUTO_REJECT, AUTO_ESCALATE
  resolvedAt     DateTime?
  resolution     String?   // REFUNDED, PARTIAL_REFUND, RETURNED, CANCELLED, DISMISSED
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  initiator User  @relation("InteractionInitiator", fields: [initiatedById], references: [id], onDelete: SetNull)
  responder User? @relation("InteractionResponder", fields: [responseById], references: [id], onDelete: SetNull)

  @@index([orderId, status])
  @@index([expiresAt, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Trust Metrics (cached — recomputed periodically)
// ─────────────────────────────────────────────────────────────────────────────

model TrustMetrics {
  id                    String   @id @default(cuid())
  userId                String   @unique
  totalOrders           Int      @default(0)
  completedOrders       Int      @default(0)
  disputeCount          Int      @default(0)
  disputeRate           Float    @default(0)    // disputeCount / totalOrders * 100
  disputesLast30Days    Int      @default(0)
  averageResponseHours  Float?                  // avg time to respond to disputes
  averageRating         Float?                  // from reviews (1-5 scale)
  dispatchPhotoRate     Float    @default(0)    // % of dispatched orders with photos
  accountAgeDays        Int      @default(0)
  isFlaggedForFraud     Boolean  @default(false)
  lastComputedAt        DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isFlaggedForFraud])
  @@index([disputeRate])
}

// ─────────────────────────────────────────────────────────────────────────────
// Offers
// ─────────────────────────────────────────────────────────────────────────────

model Offer {
  id        String @id @default(cuid())
  listingId String
  buyerId   String
  sellerId  String
  
  amountNzd Int   // Offer amount in cents
  note      String? @db.VarChar(300)
  
  status    OfferStatus @default(PENDING)
  
  // Expiry — offers expire after 48 hours by default
  expiresAt DateTime

  // Payment deadline — set 24 hours after seller accepts
  // If buyer has not paid by this time the listing is released back to ACTIVE
  paymentDeadline DateTime?

  respondedAt DateTime?
  declineNote String?   @db.VarChar(300)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id])
  buyer   User    @relation("BuyerOffers", fields: [buyerId], references: [id])
  seller  User    @relation("SellerOffers", fields: [sellerId], references: [id])

  @@index([listingId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([expiresAt])
  @@index([listingId, status])
  @@index([buyerId, status])
  @@index([status, paymentDeadline], map: "Offer_status_paymentDeadline_idx")
}

// ─────────────────────────────────────────────────────────────────────────────
// Reviews
// ─────────────────────────────────────────────────────────────────────────────

enum ReviewerRole {
  BUYER   // Buyer reviews the seller
  SELLER  // Seller reviews the buyer
}

model Review {
  id           String       @id @default(cuid())
  orderId      String
  reviewerRole ReviewerRole @default(BUYER)
  subjectId    String       // The user being reviewed
  authorId     String       // The user writing the review

  // Rating stored as integer 1–50 (represents 1.0–5.0 in 0.1 increments)
  rating     Int
  comment    String @db.Text

  reply      String?   @db.Text   // Subject's reply to the review
  repliedAt  DateTime?

  // Moderation
  approved    Boolean  @default(true)
  flagged     Boolean  @default(false)
  flagReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order @relation(fields: [orderId], references: [id])
  subject User  @relation("ReviewSubject", fields: [subjectId], references: [id])
  author  User  @relation("ReviewAuthor", fields: [authorId], references: [id])
  tags    ReviewTag[]

  @@unique([orderId, reviewerRole])
  @@index([subjectId])
  @@index([authorId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Messaging
// ─────────────────────────────────────────────────────────────────────────────

model MessageThread {
  id          String @id @default(cuid())
  listingId   String?
  participant1Id String
  participant2Id String
  
  lastMessageAt DateTime @default(now())
  
  createdAt DateTime @default(now())

  messages Message[]

  @@unique([participant1Id, participant2Id, listingId])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([lastMessageAt])
}

model Message {
  id        String @id @default(cuid())
  threadId  String
  senderId  String
  
  body String @db.Text
  read Boolean @default(false)
  readAt DateTime?
  
  // Content moderation
  flagged    Boolean @default(false)
  flagReason String?
  
  createdAt DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("MessageSender", fields: [senderId], references: [id])

  @@index([threadId])
  @@index([senderId])
  @@index([createdAt])
  @@index([senderId, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// Watchlist
// ─────────────────────────────────────────────────────────────────────────────

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  // Price drop alerts (Feature P1-3)
  priceAlertEnabled Boolean @default(true)
  priceAtWatch      Int?    // price in NZD cents at time of watch

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@index([listingId, priceAlertEnabled])
}

// ─────────────────────────────────────────────────────────────────────────────
// Payouts
// ─────────────────────────────────────────────────────────────────────────────

model Payout {
  id      String @id @default(cuid())
  orderId String @unique
  userId  String

  amountNzd          Int          // Amount in cents after platform fee
  platformFeeNzd     Int          // KiwiMart's cut (0 during beta)
  stripeFeeNzd       Int          // Stripe processing fee
  
  status    PayoutStatus @default(PENDING)
  
  stripeTransferId String? @unique
  
  initiatedAt DateTime?
  paidAt      DateTime?
  failedAt    DateTime?
  failReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit Log — immutable, append-only
// ─────────────────────────────────────────────────────────────────────────────

/// HIGH GROWTH TABLE — Partitioning Strategy:
/// At ~5M rows (est. 6-12 months at 1K DAU), partition by month on createdAt.
/// Same pattern as OrderEvent. Retain 24 months live, archive remainder.
/// Consider pg_partman extension for automated partition management.
model AuditLog {
  id     String      @id @default(cuid())
  userId String?     // null for system actions
  action AuditAction
  
  // Entity being acted on
  entityType String?
  entityId   String?
  
  // Snapshot of changes (JSON diff)
  metadata   Json?
  
  // Request context for forensics
  ip        String?
  userAgent String?
  
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications — in-app bell notifications for users
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // NotificationType — see notification.service.ts
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?  // Deep-link to relevant page
  listingId String?  // Optional reference for context
  orderId   String?  // Optional reference for context
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([userId, createdAt(sort: Desc)], map: "Notification_userId_createdAt_desc_idx")
  @@index([userId, orderId, type], map: "Notification_userId_orderId_type_idx")
}

// ─────────────────────────────────────────────────────────────────────────────
// Stripe Event Idempotency — prevents duplicate webhook processing
// ─────────────────────────────────────────────────────────────────────────────

model StripeEvent {
  id          String   @id // Stripe event ID e.g. evt_xxx
  type        String
  processedAt DateTime @default(now())

  @@map("stripe_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Categories (managed in code — this table is seeded, not user-editable)
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id           String @id
  name         String @unique
  icon         String // emoji
  slug         String @unique
  displayOrder Int    @default(0)
  active       Boolean @default(true)
  
  subcategories Subcategory[]

  @@index([slug])
}

model Subcategory {
  id         String @id @default(cuid())
  categoryId String
  name       String
  slug       String

  category Category @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, slug])
  @@index([categoryId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Admin Invitations — token-based invite system for onboarding new admin team
// ─────────────────────────────────────────────────────────────────────────────

model AdminInvitation {
  id          String     @id @default(cuid())
  email       String     @unique
  adminRole   AdminRole
  invitedBy   String
  inviter     User       @relation("InvitedBy", fields: [invitedBy], references: [id])
  tokenHash   String     @unique  // SHA-256 hash of the raw token (raw sent in email, never stored)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())

  @@index([tokenHash])
  @@index([email])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phone Verification Tokens
// ─────────────────────────────────────────────────────────────────────────────

model PhoneVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  // Store the HASH of the 6-digit code — raw code sent by SMS only, never stored
  codeHash  String
  phone     String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0) // Track failed verification attempts
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
}

// ─────────────────────────────────────────────────────────────────────────────
// Block User
// ─────────────────────────────────────────────────────────────────────────────

model BlockedUser {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocks",    fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Reports (Trust & Safety)
// ─────────────────────────────────────────────────────────────────────────────

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  // The user being reported (seller or buyer)
  targetUserId String?
  // The listing being reported (optional)
  listingId   String?

  reason      ReportReason
  description String       @db.Text
  status      ReportStatus @default(OPEN)

  // Admin resolution
  resolvedBy    String?
  resolvedAt    DateTime?
  resolvedNote  String?    @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reporter   User  @relation("ReportFiler", fields: [reporterId], references: [id])
  targetUser User? @relation("ReportTarget", fields: [targetUserId], references: [id])

  @@index([reporterId])
  @@index([targetUserId])
  @@index([listingId])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Shopping Cart — single-seller constraint, DB-persisted
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id       String @id @default(cuid())
  userId   String @unique  // One cart per user
  sellerId String          // All items must belong to this seller

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime        // 48 hours after last update

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@index([expiresAt])
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  listingId String

  // Price snapshot at time of add (NZD cents) — re-validated at checkout
  priceNzd    Int
  shippingNzd Int @default(0)

  createdAt DateTime @default(now())

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id])

  @@unique([cartId, listingId])  // No duplicate items
  @@index([cartId])
  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Order Items — line items for multi-item orders (cart checkout)
// ─────────────────────────────────────────────────────────────────────────────

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  listingId String

  // Price snapshot at time of purchase (NZD cents)
  priceNzd    Int
  shippingNzd Int @default(0)
  title       String  // Denormalised — listing may change/delete

  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Listing Snapshot — immutable copy of a listing captured at order creation
// ─────────────────────────────────────────────────────────────────────────────
// Written once when an order is created; never updated.
// Used in disputes so a seller cannot edit their listing after purchase and
// change the evidence. Admin dispute view always shows the snapshot, not the
// live listing.

model ListingSnapshot {
  id              String   @id @default(cuid())
  orderId         String   @unique
  listingId       String

  title           String
  description     String          @db.Text
  condition       ListingCondition
  priceNzd        Int
  shippingNzd     Int
  categoryName    String
  subcategoryName String?
  shippingOption  ShippingOption
  isNegotiable    Boolean

  // JSON arrays stored as opaque blobs — see listing-snapshot.service.ts for shape
  images          Json    // [{ r2Key: string, thumbnailKey: string | null, order: number }]
  attributes      Json    // [{ label: string, value: string, order: number }]

  capturedAt      DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  @@index([listingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Pickup Reschedule Requests
// ─────────────────────────────────────────────────────────────────────────────

model PickupRescheduleRequest {
  id              String                    @id @default(cuid())
  orderId         String
  requestedById   String
  requestedByRole String                    // BUYER or SELLER

  sellerReason    SellerRescheduleReason?
  buyerReason     BuyerRescheduleReason?
  reasonNote      String?                   @db.Text

  proposedTime    DateTime
  status          RescheduleRequestStatus   @default(PENDING)

  responseNote    String?
  respondedAt     DateTime?
  expiresAt       DateTime
  rescheduleJobId String?

  createdAt       DateTime                  @default(now())

  order           Order                     @relation(fields: [orderId], references: [id])
  requestedBy     User                      @relation(fields: [requestedById], references: [id])

  @@index([orderId])
  @@index([status, expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Seller Verification Applications (Feature P1-4)
// ─────────────────────────────────────────────────────────────────────────────

model VerificationApplication {
  id               String             @id @default(cuid())
  sellerId         String             @unique
  seller           User               @relation(fields: [sellerId], references: [id])
  status           VerificationStatus @default(PENDING)
  appliedAt        DateTime           @default(now())
  reviewedAt       DateTime?
  reviewedBy       String?
  adminNotes       String?
  // Document upload fields (Sprint 4A)
  documentType     String?   // DRIVERS_LICENSE, PASSPORT, NZ_FIREARMS_LICENCE, OTHER_GOV_ID
  documentFrontKey String?   // R2 key for front of document
  documentBackKey  String?   // R2 key for back of document
  selfieKey        String?   // R2 key for selfie holding ID

  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Listing Price History (Feature P2-2)
// ─────────────────────────────────────────────────────────────────────────────

model ListingPriceHistory {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  priceNzd  Int      // price in NZD cents
  changedAt DateTime @default(now())

  @@index([listingId, changedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Review Tags (buyer-selected strength chips)
// ─────────────────────────────────────────────────────────────────────────────

enum ReviewTagType {
  FAST_SHIPPING
  GREAT_PACKAGING
  ACCURATE_DESCRIPTION
  QUICK_COMMUNICATION
  FAIR_PRICING
  AS_DESCRIBED
}

model ReviewTag {
  id       String        @id @default(cuid())
  reviewId String
  review   Review        @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag      ReviewTagType

  @@unique([reviewId, tag])
  @@index([tag])
}

// ─────────────────────────────────────────────────────────────────────────────
// Recently Viewed Listings (authenticated users)
// ─────────────────────────────────────────────────────────────────────────────

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId, viewedAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// Platform Configuration (admin-editable business rules)
// ─────────────────────────────────────────────────────────────────────────────

model PlatformConfig {
  id          String          @id @default(cuid())
  key         String          @unique
  value       String          @db.Text
  type        ConfigValueType
  category    ConfigCategory
  label       String
  description String          @db.Text
  unit        String?
  minValue    String?
  maxValue    String?
  updatedBy   String?
  updatedAt   DateTime        @updatedAt
  createdAt   DateTime        @default(now())

  updater     User?           @relation(fields: [updatedBy], references: [id])

  @@index([category])
}

// ─────────────────────────────────────────────────────────────────────────────
// Dynamic Lists — admin-editable content lists (keywords, regions, reasons)
// ─────────────────────────────────────────────────────────────────────────────

model DynamicListItem {
  id          String          @id @default(cuid())
  listType    DynamicListType
  value       String          // primary value (keyword, region name, etc.)
  label       String?         // display label (if different from value)
  description String?         @db.Text
  metadata    Json?           // extra fields: emoji, colour, lat/lng, hints, etc.
  sortOrder   Int             @default(0)
  active      Boolean         @default(true)
  updatedBy   String?
  updatedAt   DateTime        @updatedAt
  createdAt   DateTime        @default(now())

  updater     User?           @relation("DynamicListUpdater", fields: [updatedBy], references: [id])

  @@unique([listType, value])
  @@index([listType, active, sortOrder])
}

